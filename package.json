{
  "name": "icon-font-reducer",
  "version": "2.3.0",
  "bin": {
    "icon-font-reducer": "dist/bin/icon-font-reducer.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "description": "CLI tool to reduce icon fonts by subsetting only used glyphs",
  "files": [
    "dist"
  ],
  "keywords": [
    "icon",
    "font",
    "subset",
    "cli",
    "optimization"
  ],
  "author": "Ariel Leyva",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "css": "^3.0.0",
    "fonteditor-core": "^2.6.3",
    "inquirer": "^13.4.1",
    "sass": "^1.99.0",
    "subset-font": "^2.5.0"
  },
  "devDependencies": {
    "@types/css": "^0.0.38",
    "@types/node": "^25.6.0",
    "@types/subset-font": "^2.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./cli": "./dist/bin/icon-font-reducer.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArielLeyva/icon-font-reducer.git"
  },
  "bugs": {
    "url": "https://github.com/ArielLeyva/icon-font-reducer/issues"
  }
}
